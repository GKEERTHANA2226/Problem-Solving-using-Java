import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		Scanner in = new Scanner(System.in);
		int t = in.nextInt();
		while(t-->0){
		   int L = in.nextInt();
		   int R = in.nextInt();
		   int result = 2 * R - 2 * L + 1;
		   System.out.println(result);
		    }

	 in.close();
	}
}
