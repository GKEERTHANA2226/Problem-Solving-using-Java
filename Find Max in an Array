import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		Scanner in = new Scanner(System.in);
		int t = in.nextInt();
		while(t-->0){
		   
		int N = in.nextInt();
		int nums[] = new int[N];
		    for(int i=0;i<N;i++){
		        nums[i] = in.nextInt();    
	    	}
	    	Arrays.sort(nums);
	    	int result = nums[N-1];
		
		    System.out.println(result);
		}
		in.close();

	}
}
