import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        int t = scanner.nextInt();
        
        while (t-- > 0) {
            int x = scanner.nextInt();
            x = x + x;
            int result = x*5;
            System.out.println(result);
            
        }
        scanner.close();
    }
}
