import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
	   Scanner sc = new Scanner(System.in);
	   int t = sc.nextInt();
	   while(t --> 0){
	       int N = sc.nextInt();
	       int K = sc.nextInt();
	       
	        if(K == 0){
	               System.out.println(N);
	           }
	              else{
	             System.out.println(N % K);
	         }
    
	}
	sc.close();
}
}
