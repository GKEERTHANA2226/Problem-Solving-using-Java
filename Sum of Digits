import java.util.*;

class Codechef
{
    public static void main (String[] args)
    {
        Scanner in = new Scanner(System.in);
        int t = in.nextInt();  

        while(t-- > 0){
            String n = in.next(); 
            int sum = 0;

            for(int i = 0; i < n.length(); i++){
                sum += n.charAt(i) - '0';  
            }

            System.out.println(sum);
        }

        in.close();
    }
}
