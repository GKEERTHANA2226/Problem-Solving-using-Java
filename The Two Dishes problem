import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		Scanner sc = new Scanner(System.in);
		int t = sc.nextInt();
     while(t --> 0){
     int n = sc.nextInt();
     int s = sc.nextInt();
     int result = Math.min(s, 2 * n - s);
     System.out.println(result);
   }
   sc.close();
	}
}
