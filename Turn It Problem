import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		Scanner sc = new Scanner(System.in);
		int t = sc.nextInt();
		while(t --> 0){
		    Double U = sc.nextDouble(), V = sc.nextDouble();
		    Double A = sc.nextDouble(), S = sc.nextDouble();
		    
		    if( U*U - 2*A*S<=(V*V)){
		        System.out.println("Yes");
		    }
		    else
		    System.out.println("NO");
		}
		sc.close();

	}
}
